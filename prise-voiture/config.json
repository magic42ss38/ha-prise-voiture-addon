{
  "name": "Prise voiture backend",
  "version": "1.0.0",
  "slug": "prise_voiture_backend",
  "description": "Backend FastAPI pour contrôler la prise voiture via l'API de Home Assistant",
  "arch": ["amd64", "armv7", "aarch64"],
  "startup": "services",
  "boot": "auto",
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "API HTTP pour la PWA"
  },
  "map": [],
  "ingress": false,
  "webui": "http://[HOST]:[PORT:8000]",
  "options": {
    "ha_base_url": "http://homeassistant.local:8123",
    "ha_token": ""
  },
  "schema": {
    "ha_base_url": "str",
    "ha_token": "str"
  }
}